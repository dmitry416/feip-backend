{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-amqp": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.3",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.0",
        "symfony/amqp-messenger": "8.0.4",
        "symfony/asset-mapper": "8.0.4",
        "symfony/config": "8.0.4",
        "symfony/console": "8.0.4",
        "symfony/dependency-injection": "8.0.4",
        "symfony/form": "8.0.4",
        "symfony/framework-bundle": "8.0.4",
        "symfony/http-foundation": "8.0.4",
        "symfony/mailer": "8.0.4",
        "symfony/messenger": "8.0.4",
        "symfony/monolog-bundle": "^4.0",
        "symfony/notifier": "8.0.4",
        "symfony/routing": "8.0.4",
        "symfony/runtime": "*",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "8.0.4",
        "symfony/stimulus-bundle": "^2.32",
        "symfony/translation": "8.0.4",
        "symfony/twig-bundle": "8.0.4",
        "symfony/validator": "8.0.4",
        "symfony/yaml": "*",
        "twig/extra-bundle": "^3.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/debug-bundle": "*",
        "symfony/maker-bundle": "^1.60",
        "symfony/stopwatch": "*",
        "symfony/web-profiler-bundle": "8.0.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true,
        "platform": {
            "php": "8.4.16",
            "ext-amqp": "2.2.0"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.4"
        }
    }
}
